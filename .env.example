# Mote Environment Variables
# Copy this file to .env and adjust values for your environment.

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection URL (requires pgvector extension)
DATABASE_URL=postgres://mote:mote_password@localhost:5432/mote

# ── Embedding Provider ──────────────────────────────────
# Which embedding backend to use: "local" (default) or "openai"
EMBEDDING_PROVIDER=local

# -- Local provider (fastembed ONNX, in-process) --
# Model name (default: BGESmallENV15, 384 dims).
# Options: BGESmallENV15, BGEBaseENV15, AllMiniLML6V2, AllMiniLML12V2,
#          NomicEmbedTextV15, NomicEmbedTextV1, MultilingualE5Small,
#          MultilingualE5Base, MultilingualE5Large, MxbaiEmbedLargeV1
# EMBEDDING_LOCAL_MODEL=BGESmallENV15

# -- OpenAI provider (HTTP API) --
# URL of the embedding API (OpenAI-compatible endpoint)
# EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
# Model name for embedding requests
# EMBEDDING_MODEL=text-embedding-3-small
# API key (required when EMBEDDING_PROVIDER=openai)
# EMBEDDING_API_KEY=sk-...

# ── Logging ──────────────────────────────────────────────
# Tracing filter (see https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html)
RUST_LOG=mote=debug,tower_http=debug

# ── Config ───────────────────────────────────────────────
# Path to the TOML configuration file (default: config.toml)
# MOTE_CONFIG=config.toml
